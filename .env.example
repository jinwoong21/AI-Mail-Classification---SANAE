# ==========================================
# 1. 프로젝트 공통 경로 (Docker Volume 매핑용)
# ==========================================
# 니 docker-compose.yml에 하드코딩 된 '/mnt/c/AIDC/semi-prj-2' 대신 이거 쓰면 편함
PROJECT_ROOT=/mnt/c/AIDC/semi-prj-2

# ==========================================
# 2. Database (PostgreSQL) 설정
# ==========================================
# docker-compose.yml이랑 파이썬 코드 양쪽에서 갖다 쓸 변수들
DB_HOST=app-db
DB_PORT=5432
DB_NAME=spam_logs_db
DB_USER=app_user
DB_PASSWORD=app_password

# ==========================================
# 3. Redis 설정 (Spark & Flask 공유)
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ==========================================
# 4. 외부 API 키 (보안 필수!)
# ==========================================
# gemini_api_key.txt 파일 내용 여기로 옮겨
GEMINI_API_KEY=your_gemini_api_key

# ==========================================
# 5. Flask 웹 설정
# ==========================================
FLASK_APP=app.py
FLASK_ENV=development
# 세션 암호화 등에 쓰이는 키
SECRET_KEY=my_super_secret_key_12345

# ==========================================
# 6. Kafka 설정
# ==========================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=email_topic